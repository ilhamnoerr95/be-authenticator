// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // module format set to cjs because prisma v7 ship an Es module by default.
  // choose cjs to nest js that force prisma to generate a commonjs module isntead of ESM
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}
model UserTester {
  id      String            @id @default(uuid())
  email    String  @unique
  username String   @unique
} 

// identity user
model IdentityUser {
// email dan username gak perlu unik karena 
// setiap applikasi pasti databasenya beda, bisa jadi email dan username bakal sama
  id      String            @id @default(uuid())
  email    String 
  username String
  isTwoFactorEnabled  Boolean  @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  twoFactorSecret    TwoFactorSecret?
  userApplication  UserApplication[]
 }
  
 model TwoFactorSecret {
  id               String   @id @default(uuid())
  userId           String   @unique
  secretEncrypted  String
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  identityUser IdentityUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

 model ClientApp {
	id              String           @id @default(uuid())
  name            String
  clientId        String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  userApplication UserApplication[]
 }
 
 model UserApplication {
  id         String   @id @default(uuid())
  userId     String
  clientAppId String
  createdAt  DateTime @default(now())

  user       IdentityUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientApp  ClientApp @relation(fields: [clientAppId], references: [id], onDelete: Cascade)

// unik: jadi 1 userid && clientAppid harus unik. rulesnya
  @@unique([userId, clientAppId])
  @@index([clientAppId])
}